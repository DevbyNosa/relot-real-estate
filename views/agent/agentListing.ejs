<%- include("../partials/agent/header.ejs") %>

<div class="dashboard-container">
<header class="form-header">
<h1>Agent Dashboard</h1>
<p>Post house details and images below</p>
</header>


<form class="listing-form" action="/agent/listings" method="POST" enctype="multipart/form-data">

<section class="form-section">
<h2><i class="fas fa-home"></i> Property Details</h2>
<div class="grid-row">
<div class="form-group full-width">
    <label>Title</label>
    <input type="text" placeholder="e.g. 4 Bedroom Duplex" name="title" required>
</div>

<div class="form-group">
    <label>Price (₦)</label>
    <input type="number" placeholder="Enter amount" name="amount" required>
</div>

<div class="form-group">
    <label>House Type</label>
    <select name="houseType" required>
        <option value="">Select Type</option>
        <option value="bungalow">Bungalow</option>
        <option value="duplex">Duplex</option>
        <option value="flat">Apartment</option>
        <option value="mansion">Mansion</option>
    </select>
</div>

<div class="form-group full-width">
    <label>Full Address</label>
    <input name="address" type="text" placeholder="Street and house number" required>
</div>

<div class="form-group">
    <label>State</label>
    <select name="state" required>
        <option value="">Select State</option>
        <option value="Abia">Abia</option><option value="Adamawa">Adamawa</option>
        <option value="Akwa Ibom">Akwa Ibom</option><option value="Anambra">Anambra</option>
        <option value="Bauchi">Bauchi</option><option value="Bayelsa">Bayelsa</option>
        <option value="Benue">Benue</option><option value="Borno">Borno</option>
        <option value="Cross River">Cross River</option><option value="Delta">Delta</option>
        <option value="Ebonyi">Ebonyi</option><option value="Edo">Edo</option>
        <option value="Ekiti">Ekiti</option><option value="Enugu">Enugu</option>
        <option value="FCT">FCT (Abuja)</option><option value="Gombe">Gombe</option>
        <option value="Imo">Imo</option><option value="Jigawa">Jigawa</option>
        <option value="Kaduna">Kaduna</option><option value="Kano">Kano</option>
        <option value="Katsina">Katsina</option><option value="Kebbi">Kebbi</option>
        <option value="Kogi">Kogi</option><option value="Kwara">Kwara</option>
        <option value="Lagos">Lagos</option><option value="Nasarawa">Nasarawa</option>
        <option value="Niger">Niger</option><option value="Ogun">Ogun</option>
        <option value="Ondo">Ondo</option><option value="Osun">Osun</option>
        <option value="Oyo">Oyo</option><option value="Plateau">Plateau</option>
        <option value="Rivers">Rivers</option><option value="Sokoto">Sokoto</option>
        <option value="Taraba">Taraba</option><option value="Yobe">Yobe</option>
        <option value="Zamfara">Zamfara</option>
    </select>
</div>

<div class="form-group">
    <label>City</label>
    <input name="city" type="text" placeholder="e.g. Ikeja" required>
</div>

<div class="form-group full-width">
    <label>Description</label>
    <textarea name="features" placeholder="Describe features..." required></textarea>
</div>
</div>
</section>


<section class="form-section">
<h2><i class="fas fa-camera"></i> Photos</h2>
<div class="upload-box">

<input type="file" 
        id="media" 
        name="property_images"   
        multiple 
        accept="image/*"
        required class="property_images">
<label for="media" style="cursor: pointer;">
    <i class="fas fa-cloud-upload-alt"></i>
    <span>Upload Photos</span><br>
    <div class="counter-badge">Max 5 Images</div>
</label>
</div>


<div id="imagePreviewContainer" class="preview-container"></div>
</section>


<section class="form-section">
<div class="grid-row">
<div class="form-group">
    <label>WhatsApp Number</label>
    
    <input type="tel" name="whatsapp" placeholder="+234 (0) 123 456 7890" required>
</div>

<div class="form-group">
    <label>Availability</label>
    <select name="houseStatus" required>
        <option value="available">Available</option>
        <option value="sold">Sold</option>
    </select>
</div>
</div>
<button style="margin-top: 3rem" type="submit" class="publish-btn">Publish Listing</button>
</section>
</form>
</div>


<script>

</script>


<%- include("../partials/agent/footer.ejs") %>