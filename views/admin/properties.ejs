<%- include("../partials/admin/header.ejs") %>

<main class="container-fluid mt-4">
<div class="row mb-4 align-items-center">
<div class="col">
<h1 class="h3">Property Management</h1>
<p class="text-muted">Total Properties: <%= properties.length %></p>
</div>
<div class="col-auto">

</div>
</div>


<div class="row g-4">
<% if (properties && properties.length > 0) { %>
<% properties.forEach(property => { 
// Parse the images JSON array
let images = [];
try {
images = JSON.parse(property.property_images || '[]');
} catch(e) {
images = [];
}

const firstImage = images.length > 0 ? images[0] : 'https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8aG91c2V8ZW58MHx8MHx8fDA%3D';


const listedDate = new Date(property.created_at).toLocaleDateString('en-US', { 
year: 'numeric', 
month: 'short', 
day: 'numeric' 
});
%>
<div class="col-12 col-md-6 col-xl-4">
<div class="card h-100 shadow-sm border-0">
<div class="position-relative">
<img src="<%= firstImage %>" 
class="card-img-top" 
alt="<%= property.title %>" 
style="height: 220px; object-fit: cover;"
onerror="this.src='https://images.unsplash.com/photo-1570129477492-45c003edd2be?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8aG91c2V8ZW58MHx8MHx8fDA%3D'">

<!-- Image count badge -->
<% if (images.length > 1) { %>
<span class="badge bg-dark position-absolute top-0 end-0 m-3 px-2 py-1">
<i class="bi bi-images"></i> <%= images.length %>
</span>
<% } %>

<span class="badge bg-<%= property.house_status === 'available' ? 'success' : 'danger' %> position-absolute top-0 start-0 m-3 px-3 py-2">
<%= property.house_status === 'available' ? 'Available' : 'Sold' %>
</span>
</div>
<div class="card-body">
<div class="d-flex justify-content-between align-items-start mb-2">
<h5 class="card-title mb-0"><%= property.title %></h5>
<span class="fw-bold text-success">₦<%= Number(property.amount).toLocaleString() %></span>
</div>
<p class="text-muted small mb-3">
<i class="bi bi-geo-alt me-1"></i> <%= property.address %>, <%= property.city %>, <%= property.state %>
</p>

<div class="d-flex gap-3 mb-4 text-secondary small border-top border-bottom py-2">
<span><i class="bi bi-door-open me-1"></i> <%= property.houseType %></span>
<span><i class="bi bi-tag me-1"></i> ID: #<%= property.id %></span>
<span><i class="bi bi-person me-1"></i> Agent: <%= property.agent_id %></span>
</div>

<div class="d-flex justify-content-between align-items-center">
<div class="btn-group">
<a href="/admin/properties/view/<%= property.id %>" class="btn btn-outline-dark btn-sm">View Details</a>
<a href="/admin/properties/edit/<%= property.id %>" class="btn btn-outline-primary btn-sm">Edit</a>
</div>
<button class="btn btn-outline-danger btn-sm" title="Delete Property" onclick="confirmDelete()">
<i class="bi bi-trash"></i>
</button>
</div>
</div>
<div class="card-footer bg-transparent border-0 text-muted small pb-3">
Listed on: <%= listedDate %>
<% if (property.is_approved) { %>
<span class="badge bg-success ms-2">Approved</span>
<% } else { %>
<span class="badge bg-warning ms-2">Pending</span>
<% } %>
</div>
</div>
</div>
<% }); %>
<% } else { %>
<div class="col-12">
<div class="alert alert-info text-center py-5">
<i class="bi bi-house-door display-1 d-block mb-3"></i>
<h4>No properties found</h4>
<p class="text-muted">There are no property listings available at the moment.</p>
</div>
</div>
<% } %>
</div>

</main>

<script>
 function confirmDelete(propertyId) {
if (confirm('Are you sure you want to delete this property?')) {
window.location.href = `/admin/properties/delete/${propertyId}`;
}
}
</script>

<%- include("../partials/admin/footer.ejs") %>