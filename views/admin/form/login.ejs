<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relot - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="bg-light"> <!-- Added bg-light for better contrast -->
    <main class="container">
        <!-- Center the card vertically and horizontally -->
        <div class="vh-100 d-flex flex-column justify-content-center align-items-center">
            
             <% if (locals.message) { %>
        <div class="text-danger bg-light p-3 border-start border-4 border-danger animation-popup messages">
            <%= message %>
        </div>
    <% } %>

            
            <form action="/admin" method="POST" 
                  class="col-11 col-sm-8 col-md-6 col-lg-4 d-flex flex-column align-items-center gap-3 p-4 bg-white shadow rounded">
                
                <h3 class="text-success mb-3">Relot - Admin</h3>
                
                <input type="email" placeholder="Email Address" required name="adminEmail" 
                       class="w-100 p-2 border border-success form-control shadow-none">
                
                <input type="password" placeholder="Password" required name="adminPassword" 
                       class="w-100 p-2 border border-success form-control shadow-none">
                
                <button class="w-100 btn btn-success p-2 fs-6 rounded-1 mt-2" type="submit">
                    Login
                </button>
            </form>
            
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/form.js"></script>
</body>
</html>
