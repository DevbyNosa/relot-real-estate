<%- include("../partials/admin/header.ejs") %>

<main class="container-fluid mt-5">
<div class="row justify-content-center">
<div class="col-12 col-md-8 col-lg-6">

<!-- Breadcrumb for navigation -->
<nav aria-label="breadcrumb" class="mb-3">
<ol class="breadcrumb small">
<li class="breadcrumb-item"><a href="/admin/users" class="text-decoration-none">Users</a></li>
<li class="breadcrumb-item active">Edit Profile</li>
</ol>
</nav>

<div class="card border-0 shadow-lg overflow-hidden">
<!-- Decorative Top Bar -->
<div class="bg-success" style="height: 6px;"></div>

<div class="card-body p-4 p-md-5">

<div class="d-flex justify-content-between align-items-start mb-4">
<div>
<h2 class="h4 fw-bold mb-1">Edit User Profile</h2>
<p class="text-muted small">Update account credentials and permissions.</p>
</div>
<div class="text-end">
<span class="badge bg-light text-dark border p-2">
<i class="bi bi-calendar3 me-1 text-success"></i>
<small class="fw-normal">Joined:</small><br>
<span class="fw-bold"><%= new Date(users.date).toDateString().split(' ').slice(1).join(' ') %>
</span>
</span>
</div>
</div>

<form action="/admin/users/<%= users.id %>" method="POST">
<!-- Name Input -->
<div class="mb-4">
<label for="name" class="form-label fw-semibold small text-uppercase">Full Name</label>
<div class="input-group">
<span class="input-group-text bg-white border-end-0"><i class="bi bi-person text-muted"></i></span>
<input type="text" class="form-control border-start-0 ps-0 focus-ring-none" id="name" name="name" value="<%= users.fullname %>" required>
</div>
</div>

<!-- Email Input -->
<div class="mb-4">
<label for="email" class="form-label fw-semibold small text-uppercase">Email Address</label>
<div class="input-group">
<span class="input-group-text bg-white border-end-0"><i class="bi bi-envelope text-muted"></i></span>
<input type="email" class="form-control border-start-0 ps-0" id="email" name="email" value="<%= users.email_address %>" required>
</div>
</div>

<!-- Status Select -->
<div class="mb-5">
<label for="status" class="form-label fw-semibold small text-uppercase">Account Status</label>
<div class="input-group">
<span class="input-group-text bg-white border-end-0"><i class="bi bi-shield-check text-muted"></i></span>
<select class="form-select border-start-0 ps-0" id="status" name="status">
    <!-- Active is true -->
    <option value="true" <%= users.status === true ? 'selected' : '' %>>Active</option>
    
    <!-- Banned is false -->
    <option value="false" <%= users.status === false ? 'selected' : '' %>>Banned</option>
</select>

</div>
</div>

<!-- Action Buttons -->
<div class="d-flex gap-3">
<button type="submit" class="btn btn-success px-4 py-2 fw-bold flex-grow-1 shadow-sm">
Save Changes
</button>
<a href="/admin/users" class="btn btn-light px-4 py-2 fw-bold border">
Cancel
</a>
</div>
</form>
</div>
</div>

<p class="text-center text-muted mt-4 small">User ID: <span class="fw-mono"><%= users.id  %></span></p>
</div>
</div>
</main>




<%- include("../partials/admin/footer.ejs") %>
