<%- include("../partials/admin/header.ejs") %> 
<style> 
  .content-card { background: #ffffff; border-radius: 8px; transition: transform 0.2s; } 
  .form-label { font-weight: 600; color: #495057; } 
  .card-editor-box { background: #f8f9fa; border-radius: 6px; padding: 20px; border: 1px solid #e9ecef; }
  .form-control:focus { border-color: #198754; box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25); } 
</style> 

<div class="container-fluid px-4"> 
  <!-- Breadcrumbs --> 
  <div class="mt-4 mb-3"> 
    <h4 class="fw-bold">Why Choose Relot</h4> 
    <nav aria-label="breadcrumb"> 
      <ol class="breadcrumb"> 
        <li class="breadcrumb-item"><a href="/admin/dashboard" class="text-decoration-none">Dashboard</a></li> 
        <li class="breadcrumb-item active" aria-current="page">Features</li> 
      </ol> 
    </nav> 
  </div> 

  <!-- Main Card --> 
  <section class="content-card shadow-sm border p-4 mb-5"> 
    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4"> 
      <h5 class="m-0 text-secondary">Edit Section Content</h5> 
      <a class="btn btn-outline-secondary btn-sm" href="/admin/dashboard"> 
        <i class="bi bi-arrow-left"></i> Back to Dashboard 
      </a> 
    </div> 

    <form action="/admin/frontend/features" method="POST" class="row g-4"> 
      
      <!-- Main H2 Title --> 
      <div class="col-12 mb-2"> 
        <label for="main_title" class="form-label">Section Main Title (H2)</label> 
        <input class="form-control form-control-lg" type="text" name="main_title" id="main_title" placeholder="e.g. Why Choose Relot" maxlength="100" value="<%=
        hero.features_title %>"> 
      </div> 

      <hr class="my-4">

      <!-- Card 1 -->
      <div class="col-lg-4">
        <div class="card-editor-box">
          <h6 class="fw-bold text-success mb-3"><i class="bi bi-1-square-fill me-2"></i>Card One</h6>
          <div class="mb-3">
            <label class="form-label small">Heading (H3)</label>
            <input type="text" class="form-control" name="card1_h3" placeholder="Card title..." value="<%= 
            hero.card1_h3%>">
          </div>
          <div>
            <label class="form-label small">Description</label>
            <textarea class="form-control" name="card1_text" rows="3" placeholder="Card text..."><%= 
            hero.card1_txt%></textarea>
          </div>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="col-lg-4">
        <div class="card-editor-box">
          <h6 class="fw-bold text-success mb-3"><i class="bi bi-2-square-fill me-2"></i>Card Two</h6>
          <div class="mb-3">
            <label class="form-label small">Heading (H3)</label>
            <input type="text" class="form-control" name="card2_h3" placeholder="Card title..." value="<%= 
            hero.card2_h3%>">
          </div>
          <div>
            <label class="form-label small">Description</label>
            <textarea class="form-control" name="card2_text" rows="3" placeholder="Card text..."><%= hero.card2_txt %></textarea>
          </div>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="col-lg-4">
        <div class="card-editor-box">
          <h6 class="fw-bold text-success mb-3"><i class="bi bi-3-square-fill me-2"></i>Card Three</h6>
          <div class="mb-3">
            <label class="form-label small">Heading (H3)</label>
            <input type="text" class="form-control" name="card3_h3" placeholder="Card title..." value="<%= 
            hero.card3_h3%>">
          </div>
          <div>
            <label class="form-label small">Description</label>
            <textarea class="form-control" name="card3_text" rows="3" placeholder="Card text..."><%= hero.card3_txt %></textarea>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="col-12 mt-5 border-top pt-4"> 
        <button type="submit" class="btn btn-success px-4">Save Changes</button> 
        <button type="reset" class="btn btn-light px-4 border">Cancel</button> 
      </div> 
    </form> 

   
      <%if(locals.success) { %>
         <div class="success-msg">
            <%= success %>
         </div>
     <% } %>
    
  </section> 
</div> 

<%- include("../partials/admin/footer.ejs") %>
