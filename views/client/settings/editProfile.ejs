<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relot - Edit Profile</title>
  <link rel="stylesheet" href="/css/global/global.css">
  <link rel="stylesheet" href="/css/settings.css">

  <style>

    input {
      padding: 10px;
      font-size: 16px;
      border-radius: 10px;
      border: 1px solid var(--bg-primary);
      outline: none;
    }
    

    input:focus {
      border: 1.5px solid var(--bg-primary);
    }

    label {
      font-size: 14px;
      text-transform: uppercase;
      color: var(--bg-primary);
    }
    </style>
</head>
<body style="background-color: #f8f9fa; font-family: 'Inter', system-ui, sans-serif; margin: 0; display: flex; justify-content: center; align-items: flex-start; min-height: 100vh; padding-top: 4rem;">
  <main style="width: 90%; max-width: 500px; background: #ffffff; padding: 2.5rem; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border: 1px solid #eaeaea;">
    
    <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
      <h1 style="font-size: 1.75rem; color: #1a1a1a; margin: 0; letter-spacing: -0.5px;">Update Account Profile</h1>
      <p style="color: #666; line-height: 1.5; margin: 0; font-size: 14px;">Modify your personal details below to keep your account information accurate and up to date.</p>
    </div>

    <form action="/edit-profile" method="POST" style="display: flex; flex-direction: column; gap: 1.5rem;">
      
      <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <label>Full Name</label>
        <input type="text" placeholder="Enter full name" name="newName" value="<%= newName %>" 
         >
      </div>

      <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <label>Email Address</label>
        <input 
  
        type="email" placeholder="Enter email address" name="newEmail" value="<%= newEmail %>" 
         >
      </div>

      <button type="submit" class="btn btn-primary" 
       style="border: 0;">
        Save Changes
      </button>

      <div style="text-align: center; border-top: 1px solid #eee; padding-top: 1.5rem;">
        <p style="font-size: 14px; color: #888; margin: 0;">
          Your profile visibility is restricted to you
        </p>
      </div>

    </form>
  </main>
</body>
</html>
