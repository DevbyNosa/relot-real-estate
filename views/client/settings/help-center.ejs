<body>
<header>
    <h class="info-main-header">About Profile</h1>
</header>
<main class="container">
  <section class="support-wrapper">
      <div class="support-header">
          <span class="online-tag"><span class="dot"></span> Support Active</span>
          <h2>How can we help?</h2>
      </div>

      <div class="support-grid" id="helpGrid">
          <a href="https://wa.me" target="_blank" class="glass-card" data-tags="whatsapp chat agent message help">
              <div class="card-icon wa"><i class="fab fa-whatsapp"></i></div>
              <h3>WhatsApp Support</h3>
              <p>Direct chat for urgent property inquiries and fast response from our team.</p>
              <span class="action-txt">Message Now <i class="fas fa-arrow-right"></i></span>
          </a>

          <a href="https://tiktok.com" target="_blank" class="glass-card" data-tags="tiktok video tours highlights tutorials">
              <div class="card-icon tt"><i class="fab fa-tiktok"></i></div>
              <h3>TikTok Channel</h3>
              <p>Watch property tours, market updates, and step-by-step video guides.</p>
              <span class="action-txt">Watch Videos <i class="fas fa-arrow-right"></i></span>
          </a>

    
      </div>
  </section>
</main>


</body>
</html>
