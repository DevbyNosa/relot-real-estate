<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relot - user settings</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&icon_names=account_circle" />
  
  <link rel="stylesheet" href="/css/global/global.css">
  <link rel="stylesheet" href="/css/settings.css">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>

<body>
  <header>
    <h1 class="info-main-header">Account Setting</h1>
   
  </header>

  <main class="info-main-container">
    <div class="settings-nav-lg">
    <a href="/account-informations" class="settings-cta"><span class="material-symbols-outlined">
account_circle
</span> Personal Information</a>
   
    <a href="/delete-account" class="settings-cta"> <img src="/assets/svg/delete_forever_24dp_1F1F1F_FILL0_wght400_GRAD0_opsz24.svg" alt="Delete Account">Delete Account</a>
    </div>

   

   <section class="settings-nav">

<div class="profile-img-container">
    <img class="profile-img" src="/images/profile-img.jpg" alt="profile image">
</div>
     <h5 class="info-name"> <%= user.fullname %> </h5>
    <p class="info-email">
  <%= user.email_address.replace(/^(.)(.*)(@.*)$/, "$1***$3") %>
</p>

 <% if(user.status === true) {%>
    <div class="verify-card">
     <img class="verify-icon" src="/assets/svg/verified_24dp_1F1F1F_FILL0_wght400_GRAD0_opsz24.svg" alt="Verified user">
     Verified Account
    </div>
    <% } else {%>
<div>
  Banned Account
</div>
      <% }%>
   
    <ul>
        <li><a href="/settings-about"><i class="fa-solid fa-user"></i> Profile Information</a></li>
        <li><a href="/change-password"><i class="fa-solid fa-lock"></i> Change Password</a></li>
        <li><a href="/help-center"><i class="fa-solid fa-circle-question"></i> Help Center</a></li>
        <li><a href="/delete-account"><i class="fa-solid fa-trash"></i> Delete Account</a></li>
        <li><a class="btn btn-primary" href="/logout"><i class="fa-solid fa-sign-out-alt"></i> Logout</a></li>
    </ul>
</section>
  </main>
</body>
</html>