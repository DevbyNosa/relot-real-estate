<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relot - about Profile</title>
  <link rel="stylesheet" href="/css/global/global.css">
  <link rel="stylesheet" href="/css/settings.css">

  <style>
    
.profile-card {
  max-width: 500px;
  margin: 40px auto;
  background: #ffffff;
  padding: 30px;
  border-radius: 12px;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  font-family: 'Segoe UI', sans-serif;
}


.info-main-header {
  text-align: center;
  color: #333;
  margin-bottom: 20px;
}

/* Grouping and Labels */
.div-info {
  margin-bottom: 20px;
}

.div-info label, 
.div-info h5 {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #666;
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* Modern Input Styling */
input[type="text"] {
  width: 100%;
  padding: 12px 15px;
  margin-bottom: 10px;
  border: 1px solid #e1e1e1;
  border-radius: 8px;
  background-color: #fcfcfc;
  color: #333;
  font-size: 16px;
  box-sizing: border-box; 
}


input[readonly] {
  background-color: #f4f7f6;
  color: #777;
  cursor: default;
  border-style: dashed;
}


.divider {
  border: 0;
  border-top: 1px solid #eee;
  margin: 25px 0;
}


.action-area {
  display: flex;
  justify-content: center;
  margin-top: 20px;
}

  </style>
</head>
<body>
     <header>
      <h1 style="color: white;" class="info-main-header">About Profile</h1>
     </header>
   <main class="profile-card">
  <div class="div-info">
    <label>Name Information</label>
    <input type="text" value="<%= fullName %>" readonly>

    <label>Email Address</label>
    <input type="text" value="<%= email %>" readonly>
  </div>

  <div class="div-info">
    <label>Date Joined</label>
    
    <input type="text" value="<%= new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>" readonly>
  </div>

  <hr class="divider">

  <div class="div-info">
    <p id="qa-p">Agent Account Details</p>
    <div class="input-group">
      <input type="text" value="<%= username %>" readonly>
      <input type="text" value="<%= phone_number %>" readonly>
    </div>
  </div>

  <div class="action-area">
    <a href="/edit-profile" class="btn btn-primary">Edit Information</a>
  </div>
</main>

</body>
</html>