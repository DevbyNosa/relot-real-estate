<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Relot - Dashboard</title>
<link rel="icon" type="image/png" href="/images/logo.png">
<link rel="stylesheet" href="/css/home.css">
<link rel="stylesheet" href="/css/global/global.css">
<link rel="stylesheet" href="/css/queries.css">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=menu" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>

<body>

<div class="house-details-container">
<% if (listing) { %>


<div class="image-gallery">
<div class="main-image">
    <img class="big-img" src="<%= images.length > 0 ? images[0] : '/images/placeholder.jpg' %>" 
            id="mainImage" 
            alt="<%= listing.title %>">
</div>


<div class="thumbnail-strip">
    <% if (images.length > 0) { %>
        <% images.forEach((img, index) => { %>
            <div class="thumbnail <%= index === 0 ? 'active' : '' %>" 
                    onclick="changeMainImage('<%= img %>', this)">
                <img src="<%= img %>" alt="Thumbnail <%= index + 1 %>">
            </div>
        <% }) %>
    <% } else { %>
        <p>No images available</p>
    <% } %>
</div>
</div>


<div class="details-section">
<h1><%= listing.title %></h1>

<div class="price-badge">
    ₦<%= Number(listing.amount).toLocaleString() %>
</div>

<div class="house-meta">
    <span class="meta-item">
        <i class="fas fa-home"></i> <%= listing.housetype %>
    </span>
    <span class="meta-item">
        <i class="fas fa-map-marker-alt"></i> <%= listing.city %>, <%= listing.state %>
    </span>
    <span class="meta-item">
        <i class="fas fa-calendar"></i> Listed: <%= new Date(listing.created_at).toLocaleDateString() %>
    </span>
    <span class="meta-item">
        <i class="fas fa-user"></i> Agent: <%= listing.username %>
    </span>
</div>

<div class="status-section">
    <span class="status-badge <%= listing.house_status %>">
        <%= listing.house_status === 'available' ? 'Available' : 'sold' %>
    </span>
</div>

<div class="features-section">
    <h6>Description</h6>
    <p><%= listing.features %></p>
</div>

<div class="contact-section">
    <h6>Contact Agent</h6>
    
    <p><i class="fab fa-whatsapp"></i> <%= listing.whatsapp || 'N/A' %></p>
    
    
</div>
</div>

<% } else { %>
<p>House not found</p>
<% } %>
</div>

<a href="https://wa.me/+234<%= listing.whatsapp.startsWith('0') ? listing.whatsapp.substring(1) : listing.whatsapp %>" class="contact-whatsapp">
<img class="whatsapp-svg" src="/assets/svg/whatsapp-color (1).svg" alt="Contact agent">

</a>

<script src="/js/home.js">

</script>

</body>
</html>
