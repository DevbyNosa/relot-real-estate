<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relot - Search result</title>
  <link rel="stylesheet" href="/css/home.css">
  <link rel="stylesheet" href="/css/global/global.css">
  
  <link rel="stylesheet" href="/css/search.css">
  <link rel="stylesheet" href="/css/queries.css">
  
</head>
<body>
  

<main>
    <div class="slide-line"></div>

    <div class="search-header">
        <h5 class="id-h5">Search Results for "<%= searchTerm %>"</h5>
        <p class="results-count"><%= totalResults %> properties found</p>
    </div>

    <% if (searchResults && searchResults.length > 0) { %>
        <div class="listings-grid">
            <% searchResults.forEach(listing => { 
                let images = [];
                try {
                    images = JSON.parse(listing.property_images || '[]');
                } catch(e) {
                    images = [];
                }
                const firstImage = images.length > 0 ? images[0] : 'https://plus.unsplash.com/premium_photo-1689609950112-d66095626efb?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D';
            %>
            
            <section class="house-card">
                <a href="/house-details/<%= listing.id %>">
                   <img src="<%= firstImage %>" 
     alt="<%= listing.title %>" 
     class="house-card-img"
     onerror="this.src='https://plus.unsplash.com/premium_photo-1689609950112-d66095626efb?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'">
                    <div class="card-content">
                        <h6><%= listing.title %></h6>
                        <div class="card-meta">
                            <span>₦<%= Number(listing.amount).toLocaleString() %></span>
                            <span><%= listing.city %></span>
                        </div>
                        <span class="status <%= listing.house_status %>">
                            <%= listing.house_status === 'available' ? 'Available' : 'Sold' %>
                        </span>
                    </div>
                </a>
            </section>
            <% }) %>
        </div>

        <% if (totalPages > 1) { %>
        <div class="pagination">
            <% if (currentPage > 1) { %>
                <a href="/search?q=<%= searchTerm %>&page=<%= currentPage - 1 %>" class="page-link">← Prev</a>
            <% } %>
            
            <% for (let p = 1; p <= totalPages; p++) { %>
                <a href="/search?q=<%= searchTerm %>&page=<%= p %>" 
                   class="page-link <%= p === currentPage ? 'active' : '' %>"><%= p %></a>
            <% } %>
            
            <% if (currentPage < totalPages) { %>
                <a href="/search?q=<%= searchTerm %>&page=<%= currentPage + 1 %>" class="page-link">Next →</a>
            <% } %>
        </div>
        <% } %>

    <% } else { %>
        <div class="no-results">
            <p>No properties found matching "<%= searchTerm %>"</p>
            <a href="/dashboard" class="back-link">← Back to Dashboard</a>
        </div>
    <% } %>
</main>

</body>
</html>