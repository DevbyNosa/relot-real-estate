<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relot - Admin </title>
  <link rel="stylesheet" href="/css/admin.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

  <link rel="icon" type="image/png" href="/images/logo.png">
  
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>
  <header>
    
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
      <div class="container-fluid">
        <button class="btn btn-outline-light me-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebar" aria-controls="sidebar">
          <i class="bi bi-list"></i>
        </button>
        <a class="navbar-brand" href="#">
          <img src="/images/logo.png" alt="Relot Logo" style="width: 80px; height: auto;">
        </a>
        <div class="d-flex align-items-center ms-auto">
          <ul class="navbar-nav">
            <li class="nav-item position-relative me-3">
              <a class="nav-link" href="/notification" role="button">
                <i class="bi bi-bell-fill"></i>
                <span class="badge bg-danger">0</span>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/me" role="button">
                <i class="bi bi-gear-fill me-1"></i>
                My Settings
              </a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    
    <div class="offcanvas offcanvas-start bg-light" tabindex="-1" id="sidebar" aria-labelledby="sidebarLabel">
      <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="sidebarLabel">Admin Menu</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body">
        <ul class="nav nav-pills flex-column">
          <li class="nav-item">
            <a class="nav-link bg-success text-white" href="/admin/dashboard">
              <i class="bi bi-house-door-fill me-2"></i> Dashboard
            </a>
          </li>
          <li class="nav-item mt-3">
            <h6 class="text-muted mb-2">User Management</h6>
          </li>
          <li class="nav-item">
            <a class="nav-link text-dark" href="/admin/users">
              <i class="bi bi-people-fill me-2"></i> View all users
            </a>
          </li>
          <li class="nav-item mt-3">
            <h6 class="text-muted mb-2">Agent Management</h6>
          </li>
          <li class="nav-item">
            <a class="nav-link text-dark" href="/admin/agents">
              <i class="bi bi-people-fill me-2"></i> View all agents
            </a>
          </li>
          <li class="nav-item mt-3">
            <h6 class="text-muted mb-2">Properties Management</h6>
          </li>
          <li class="nav-item">
            <a class="nav-link text-dark" href="/admin/properties">
              <i class="bi bi-houses-fill me-2"></i> View all Properties
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link text-dark" href="/admin/listings">
              <i class="bi bi-check-circle me-2"></i> Approve new listings
            </a>
          </li>
          <li class="nav-item mt-3">
            <h6 class="text-muted mb-2">Frontend - Settings</h6>
          </li>
          <li class="nav-item">
            <a class="nav-link text-dark" href="/admin/maintenance">
              Change site status
            </a>
          </li>

            <li class="nav-item">
            <a class="nav-link text-dark" href="/admin/frontend/home">
              Frontend - Hero
            </a>

              <a class="nav-link text-dark" href="/admin/frontend/about">
              Frontend - About
            </a>

              <a class="nav-link text-dark" href="/admin/frontend/features">
              Frontend - Features
            </a>

              <a class="nav-link text-dark" href="/admin/frontend/testimonials">
              Frontend - Testimonials
            </a>
          </li>
        </ul>
      </div>
    </div>
  </header>
