<body>
  
  <header>
   <nav class="dashboard-nav">
     <span class="admin-display-name">
     <img src="/assets/svg/account_child_invert_24dp_1F1F1F_FILL0_wght400_GRAD0_opsz24.svg" alt="Account svg" class="mini-icon">
    <h3 style="color: white;">Welcome, <%= agentdetails?.username || agent?.username || 'Agent' %></h3>
     </span>

     <span style="display: flex; gap: 4rem;" class="agent-routes">
        <a href="/agent/listings">List a home</a>
       <div class="wrapper-routes">
        <a href="/agent/view/listings">My listing</a>
        </div>
     </span>
    <span class="cta-dashboard">
      <a href="/dashboard"class="nav-agent-link">Switch to user</a>
      <button class="sidebar-btn">
      <img src="/assets/svg/menu_24dp_1F1F1F_FILL0_wght400_GRAD0_opsz24 (2).svg" alt="Sidebar Menu" class="dashboard-menu-icon">
      </button>
     
    </span>
   </nav>

   <nav class="dashboard-sidebar">
         <a href="/account-settings" class="sidebar-anchor">
          <img src="/assets/svg/settings_24dp_1F1F1F_FILL0_wght400_GRAD0_opsz24.svg" alt="Wishlist link image" class="wishlist-svg">
         Account Settings
         </a>

       <a href="/help-center" class="sidebar-anchor">
         <img src="/assets/svg/help_center_24dp_1F1F1F_FILL0_wght400_GRAD0_opsz24.svg" alt="Help Center">
         Help Center
       </a>

       <div class="sidebar-anchor become-agent-anchor" style="display: flex; flex-direction: column; align-items: flex-start;
       margin-right: 1rem;">
        <a href="/agent/listings" class="sidebar-anchor">
         <img src="/assets/svg/add_24dp_1F1F1F_FILL0_wght400_GRAD0_opsz24.svg" alt="Help Center">
         Create new listing
       </a>

       <a href="/agent/view/listings" class="sidebar-anchor">
        <img src="/assets/svg/view_agenda_24dp_1F1F1F_FILL0_wght400_GRAD0_opsz24.svg" alt="View Listing">
        View Listing
       </a>
       </div>

<a href="/logout" class="sidebar-anchor logout">
         
         Log out
         </a>

      </nav>

       <h5 style="color: #5d5c5c; padding: 2.5rem; background-color: #edecec; box-shadow: 2px 2px 2px #dbd9d9; position: fixed; width: 100%; z-index: 999;" class="agent-name">👋 Welcome, <%= agentdetails?.username || agent?.username || 'Agent' %></h5>
      
  </header>
  <main style="padding-bottom: 5rem;">